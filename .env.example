# ============================================
# CONFIGURAÇÃO DO BOT DISCORD
# ============================================
# Token do bot (Discord Developer Portal > Bot > Token)
DISCORD_TOKEN=seu_token_aqui

# ID da aplicação (Discord Developer Portal > General Information > Application ID)
DISCORD_CLIENT_ID=seu_client_id_aqui

# ID do servidor (Guild) — clique com botão direito no ícone do servidor com modo desenvolvedor ativado
DISCORD_GUILD_ID=seu_guild_id_aqui

# ============================================
# CONFIGURAÇÃO DO SUPABASE
# ============================================
# URL do projeto Supabase (Settings > API > Project URL)
SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anônima ou service_role (Settings > API > anon/service_role key)
SUPABASE_KEY=sua_chave_aqui
